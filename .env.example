# Copy this file to ".env" and fill in your own values. The .env file is
# gitignored so your keys are never committed.
#
# USDA NASS Quick Stats API key — enables the county crop-acreage data source
# (crop-context features + "lbs per cropland acre" normalization).
# Get a free key at: https://quickstats.nass.usda.gov/api
NASS_API_KEY=
